# App
PROJECT_NAME=AI Health Trainer
API_V1_PREFIX=/api/v1
DEBUG=false
ENVIRONMENT=production
BACKEND_CORS_ORIGINS=https://yourdomain.com

# Database
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=health_trainer
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}
DATABASE_URL_SYNC=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_32CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
GEMINI_API_KEY=CHANGE_ME
AI_DEFAULT_MODEL=gemini-2.5-flash
AI_ADVANCED_MODEL=gemini-2.5-pro
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_MAX_OUTPUT_TOKENS=1000
AI_TEMPERATURE=0.7
AI_DAILY_REQUEST_LIMIT=30

# Upload
UPLOAD_DIR=/data/uploads
MAX_IMAGE_SIZE_MB=10
