# App
PROJECT_NAME=AI Health Trainer
API_V1_PREFIX=/api/v1
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health_trainer
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/health_trainer

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# AI settings
AI_DEFAULT_MODEL=gemini-3-flash-preview
AI_ADVANCED_MODEL=gemini-2.5-pro
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_MAX_OUTPUT_TOKENS=4096
AI_TEMPERATURE=0.7
AI_DAILY_REQUEST_LIMIT=30
RAG_OPENSEARCH_INDEX=rag_chunks_v1
RAG_OPENSEARCH_ALIAS=rag_chunks_current
RAG_VECTOR_WEIGHT=0.65
RAG_KEYWORD_WEIGHT=0.35
RAG_PARTIAL_REFRESH_CHANGE_RATIO=0.30
RAG_PARSER_CONFIDENCE_THRESHOLD=0.70
RAG_ALLOWED_REEMBEDDING_SECONDS=300
RAG_ESTIMATED_EMBEDDING_SECONDS_PER_CHUNK=1.5
RAG_URL_FETCH_TIMEOUT_SECONDS=20
RAG_URL_MAX_BYTES=2000000
RAG_URL_USER_AGENT=AIHealthTrainerRAG/1.0

# Upload
UPLOAD_DIR=/data/uploads
MAX_IMAGE_SIZE_MB=10

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
