# App
PROJECT_NAME=AI Health Trainer
API_V1_PREFIX=/api/v1
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health_trainer
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/health_trainer

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# AI settings
AI_DEFAULT_MODEL=gemini-3-flash-preview
AI_ADVANCED_MODEL=gemini-2.5-pro
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_MAX_OUTPUT_TOKENS=4096
AI_TEMPERATURE=0.7
AI_DAILY_REQUEST_LIMIT=30

# Upload
UPLOAD_DIR=/data/uploads
MAX_IMAGE_SIZE_MB=10

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
